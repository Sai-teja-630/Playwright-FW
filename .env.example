# ============================================================
# Playwright Framework - Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# Usage: dotenv loads these automatically before test runs.
# ============================================================

# Target environment: test | stage | beta | prod
ENV=test

# Browser: chromium | firefox | webkit
BROWSER=chromium

# Parallel workers (number or percentage like 50%)
WORKERS=2

# Headed mode: true | false
HEADED=false

# Retry count for failed tests
RETRIES=0

# Tags to filter (Playwright grep pattern)
# Examples: @smoke, @regression, @login
GREP=

# CI mode flag
CI=false
